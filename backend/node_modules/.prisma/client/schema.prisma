// Prisma Schema for Footwear Billing System
// Run: npx prisma migrate dev --name init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── USERS ──────────────────────────────────────────────────────────────────
model User {
  id           Int      @id @default(autoincrement())
  name         String
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         UserRole @default(STAFF)
  createdAt    DateTime @default(now()) @map("created_at")

  invoices Invoice[]

  @@map("users")
}

enum UserRole {
  ADMIN
  STAFF
}

// ─── CUSTOMERS ───────────────────────────────────────────────────────────────
model Customer {
  id            Int      @id @default(autoincrement())
  name          String
  phone         String   @unique
  email         String?
  creditBalance Decimal  @default(0) @map("credit_balance") @db.Decimal(10, 2)
  createdAt     DateTime @default(now()) @map("created_at")

  invoices Invoice[]
  payments Payment[]

  @@map("customers")
}

// ─── PRODUCTS ────────────────────────────────────────────────────────────────
model Product {
  id          Int      @id @default(autoincrement())
  name        String
  brand       String?
  category    String?
  description String?
  imageUrl    String?  @map("image_url")
  createdAt   DateTime @default(now()) @map("created_at")

  variants Variant[]

  @@map("products")
}

// ─── VARIANTS (Size-based Stock) ─────────────────────────────────────────────
model Variant {
  id            Int      @id @default(autoincrement())
  productId     Int      @map("product_id")
  size          String // e.g. "UK 6", "UK 7", "UK 8"
  sku           String   @unique
  barcode       String?  @unique
  price         Decimal  @db.Decimal(10, 2)
  stock         Int      @default(0)
  lowStockLimit Int      @default(5) @map("low_stock_limit")
  createdAt     DateTime @default(now()) @map("created_at")

  product      Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  invoiceItems InvoiceItem[]

  @@map("variants")
}

// ─── INVOICES ────────────────────────────────────────────────────────────────
model Invoice {
  id          Int           @id @default(autoincrement())
  invoiceNo   String        @unique @map("invoice_no")
  customerId  Int?          @map("customer_id")
  userId      Int           @map("user_id")
  subtotal    Decimal       @db.Decimal(10, 2)
  cgst        Decimal       @default(0) @db.Decimal(10, 2)
  sgst        Decimal       @default(0) @db.Decimal(10, 2)
  igst        Decimal       @default(0) @db.Decimal(10, 2)
  discount    Decimal       @default(0) @db.Decimal(10, 2)
  total       Decimal       @db.Decimal(10, 2)
  paymentMode PaymentMode   @map("payment_mode")
  status      InvoiceStatus @default(PAID)
  notes       String?
  createdAt   DateTime      @default(now()) @map("created_at")

  customer Customer?     @relation(fields: [customerId], references: [id])
  user     User          @relation(fields: [userId], references: [id])
  items    InvoiceItem[]
  payments Payment[]

  @@map("invoices")
}

enum PaymentMode {
  CASH
  UPI
  CARD
  UDHAAR
  MIXED
}

enum InvoiceStatus {
  PAID
  PARTIAL
  UNPAID
  CANCELLED
}

// ─── INVOICE ITEMS ───────────────────────────────────────────────────────────
model InvoiceItem {
  id         Int     @id @default(autoincrement())
  invoiceId  Int     @map("invoice_id")
  variantId  Int?    @map("variant_id")
  customName String? @map("custom_name")
  qty        Int
  unitPrice  Decimal @map("unit_price") @db.Decimal(10, 2)
  taxRate    Decimal @default(18) @map("tax_rate") @db.Decimal(5, 2)
  discount   Decimal @default(0) @db.Decimal(10, 2)
  total      Decimal @db.Decimal(10, 2)

  invoice Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  variant Variant? @relation(fields: [variantId], references: [id])

  @@map("invoice_items")
}

// ─── PAYMENTS ────────────────────────────────────────────────────────────────
model Payment {
  id         Int         @id @default(autoincrement())
  invoiceId  Int         @map("invoice_id")
  customerId Int?        @map("customer_id")
  amount     Decimal     @db.Decimal(10, 2)
  mode       PaymentMode
  note       String?
  createdAt  DateTime    @default(now()) @map("created_at")

  invoice  Invoice   @relation(fields: [invoiceId], references: [id])
  customer Customer? @relation(fields: [customerId], references: [id])

  @@map("payments")
}

// ─── EXPENSES ────────────────────────────────────────────────────────────────
model Expense {
  id        Int      @id @default(autoincrement())
  category  String // e.g. Rent, Salary, Utility, Stock Purchase
  amount    Decimal  @db.Decimal(10, 2)
  note      String?
  date      DateTime @default(now())
  createdAt DateTime @default(now()) @map("created_at")

  @@map("expenses")
}
